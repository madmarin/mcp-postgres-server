# ── Connection (Option A: full URL) ───────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/mydb

# ── Connection (Option B: individual fields) ──────────────────────────────────
# Used only when DATABASE_URL is not set
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=mydb
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secret

# ── Server ────────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=mcp-postgres
MCP_TRANSPORT=stdio          # stdio | sse
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Safety ────────────────────────────────────────────────────────────────────
# Set to true to allow INSERT / UPDATE / DELETE / DDL via the execute tool.
# Defaults to false (read-only mode).
ALLOW_WRITE=false

# ── Connection Pool ───────────────────────────────────────────────────────────
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
QUERY_TIMEOUT=30.0
